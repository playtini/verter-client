{
    "name": "verter/client",
    "description": "Verter Client",
    "type": "library",
    "license": "proprietary",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require": {
        "php": "^8.4",
        "ext-mbstring": "*",
        "psr/log": "^3.0",
        "symfony/http-client": "^8.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^13.0"
    },
    "config": {
        "preferred-install": {
            "*": "dist"
        },
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "VerterClient\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "VerterClient\\Tests\\": "tests/"
        }
    }
}
